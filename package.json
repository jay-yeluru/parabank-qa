{
  "name": "parabank-qa",
  "version": "1.0.0",
  "description": "E2E test automation framework for ParaBank using Playwright (JavaScript)",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test tests/ui/",
    "test:api": "playwright test tests/api/",
    "test:serial": "playwright test --workers=1",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "test:stage": "TEST_ENV=stage npx playwright test",
    "test:beta": "TEST_ENV=beta npx playwright test",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jay-yeluru/parabank-qa.git"
  },
  "keywords": [
    "playwright",
    "e2e",
    "automation",
    "parabank",
    "testing"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "allure-playwright": "^3.6.0",
    "dotenv": "^17.3.1",
    "prettier": "^3.8.1"
  },
  "dependencies": {
    "resend": "^6.9.4"
  }
}
