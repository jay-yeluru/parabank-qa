{
  "name": "parabank-qa",
  "version": "1.0.0",
  "description": "E2E test automation framework for ParaBank using Playwright (JavaScript)",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test tests/ui/",
    "test:api": "playwright test tests/api/",
    "test:serial": "playwright test --workers=1",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jay-yeluru/parabank-qa.git"
  },
  "keywords": [
    "playwright",
    "e2e",
    "automation",
    "parabank",
    "testing"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "dotenv": "^16.4.7"
  }
}
